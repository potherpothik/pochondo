<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_res_config_settings_shop_suite" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.shop.suite</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='base_setup']" position="after">
                <app string="Shop Suite" name="shop_suite" groups="sales_team.group_sale_manager">
                    <block title="Inventory Alerts">
                        <setting string="Low Stock Threshold">
                            <field name="shop_suite_low_stock_threshold"/>
                        </setting>
                        <setting string="Alert Recipients">
                            <field name="shop_suite_stock_alert_partner_ids" widget="many2many_tags"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
