<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_shop_suite_manager" model="res.groups">
        <field name="name">Shop Suite Manager</field>
        <field name="category_id" ref="base.module_category_sales_management"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_manager')), (4, ref('sales_team.group_sale_manager'))]"/>
    </record>

    <record id="group_shop_suite_user" model="res.groups">
        <field name="name">Shop Suite User</field>
        <field name="category_id" ref="base.module_category_sales_management"/>
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user')), (4, ref('sales_team.group_sale_salesman'))]"/>
    </record>
</odoo>
