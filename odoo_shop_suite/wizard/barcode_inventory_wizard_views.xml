<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_shop_barcode_inventory_wizard_form" model="ir.ui.view">
        <field name="name">shop.barcode.inventory.wizard.form</field>
        <field name="model">shop.barcode.inventory.wizard</field>
        <field name="arch" type="xml">
            <form string="Barcode Inventory Update">
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="barcode"/>
                        <field name="location_id"/>
                        <field name="quantity_delta"/>
                        <field name="note"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_apply_adjustment" type="object" string="Apply" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
